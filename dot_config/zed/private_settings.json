// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "soft_wrap": "editor_width",
  "cli_default_open_behavior": "new_window",
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "proxy": "",
  "buffer_font_weight": 400.0,
  "git": {
    "blame": {
      "show_avatar": true,
    },
    "inline_blame": {
      "enabled": false,
      "min_column": 0,
      "show_commit_summary": false,
    },
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "agent": {
    "dock": "right",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5.2",
    },
    "model_parameters": [],
  },
  "icon_theme": {
    "mode": "light",
    "light": "VSCode Icons for Zed (Dark Official Icons)",
    "dark": "VSCode Icons for Zed (Dark Official Icons)",
  },
  "terminal": {
    "dock": "right",
  },
  "use_system_window_tabs": false,
  "bottom_dock_layout": "contained",
  "tabs": {
    "show_close_button": "hover",
    "file_icons": true,
    "git_status": false,
  },
  "title_bar": {
    "show_menus": false,
    "show_user_picture": true,
    "show_branch_name": true,
  },
  "status_bar": {
    "cursor_position_button": true,
  },
  "project_panel": {
    "dock": "left",
    "hide_gitignore": false,
    "hide_root": false,
    "hide_hidden": false,
    "entry_spacing": "standard",
    "button": true,
  },
  "lsp_document_colors": "inlay",
  "inlay_hints": {
    "show_background": false,
    "show_other_hints": true,
    "show_parameter_hints": true,
    "show_type_hints": false,
    "show_value_hints": true,
    "enabled": true,
  },
  "show_whitespaces": "boundary",
  "indent_guides": {
    "background_coloring": "disabled",
    "coloring": "indent_aware",
    "active_line_width": 1,
    "line_width": 1,
  },
  "preferred_line_length": 120,
  "tab_size": 2,
  "toolbar": {
    "code_actions": false,
    "breadcrumbs": true,
  },
  "minimap": {
    "display_in": "all_editors",
    "current_line_highlight": "all",
    "thumb_border": "left_open",
    "thumb": "always",
    "show": "always",
  },
  "gutter": {
    "runnables": true,
    "line_numbers": true,
  },
  "hover_popover_enabled": false,
  "auto_signature_help": false,
  "vertical_scroll_margin": 50.0,
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "cursor_shape": "bar",
  "ui_font_weight": 400.0,
  "ui_font_family": ".ZedSans",
  "buffer_line_height": {
    "custom": 1.5,
  },
  "buffer_font_family": "MesloLGS NF",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "buffer_font_size": 12.0,
  "theme": {
    "mode": "dark",
    "light": "Ayu Mirage",
    "dark": "Ayu Mirage",
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "vtsls": {
          "experimental": {
            "maxInlayHintLength": 15,
          },
        },
      },
    },
    "tinymist": {
      "initialization_options": {
        // Enable background preview
        // Server will be running on 127.0.0.1:23635
        "preview": {
          "background": {
            "enabled": true,
          },
        },
      },

      "settings": {
        // Compile on save
        // This will compile a PDF for the `main.typ` file in the project root.
        // "exportPdf": "onSave",
        // "outputPath": "$root/$name",

        // Enable formatter
        "formatterMode": "typstyle",
      },
    },
  },
}
